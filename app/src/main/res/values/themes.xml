<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.WaitWise" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">#003082</item>
        <item name="colorPrimaryVariant">#001F50</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">#FFC107</item>
        <item name="colorSecondaryVariant">#FFA000</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">#003082</item>

        <!-- Background color -->
        <item name="android:windowBackground">#F4F5F7</item>
    </style>

    <!-- Splash screen theme (No ActionBar) -->
    <style name="Theme.WaitWise.NoActionBar" parent="Theme.WaitWise">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>