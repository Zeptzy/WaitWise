<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#003082"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/waitwise_circle"
        android:background="@drawable/circle_white_outline"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:contentDescription="Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="University of Cebu"
        android:textColor="#F0C040"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WaitWise"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Queue Monitoring System"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <ProgressBar
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#FFFFFF" />

</LinearLayout>