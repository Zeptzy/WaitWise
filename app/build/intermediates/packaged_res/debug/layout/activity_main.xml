<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Top Blue Header ── -->
        <LinearLayout
            android:id="@+id/llHeader"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#003082"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/waitwise_circle"
                android:background="@drawable/circle_white_outline"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:contentDescription="UC Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="University of Cebu"
                android:textColor="#F0C040"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WaitWise"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Queue Monitoring System"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/waitwise_circle" />

        </LinearLayout>

        <!-- ── White Card Form ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:id="@+id/llForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="#003082"
                    android:textSize="22sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Access your WaitWise account"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="20dp" />

                <!-- ── Error Banner ── -->
                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:background="@drawable/error_bg"
                    android:text=""
                    android:textColor="#991B1B"
                    android:textSize="13sp"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp" />

                <!-- ── Email Field ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Student Email"
                    android:layout_marginBottom="14dp"
                    app:hintTextColor="#003082"
                    app:boxStrokeColor="#003082"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textSize="14sp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:textColor="#111827" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Password Field with Show/Hide ── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:layout_marginBottom="8dp"
                    app:hintTextColor="#003082"
                    app:boxStrokeColor="#003082"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#003082"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="14sp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:textColor="#111827" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Remember Me + Forgot Password ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:id="@+id/cbRememberMe"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Remember me"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:buttonTint="#003082" />

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot password?"
                        android:textColor="#003082"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- ── Sign In Button ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Sign In"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/btn_primary"
                        android:stateListAnimator="@null" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#FFFFFF" />

                </FrameLayout>

                <!-- ── Divider ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#E5E7EB" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="or continue with"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp" />
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#E5E7EB" />

                </LinearLayout>

                <!-- ── Continue with Google Button ── -->
                <Button
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Continue with Google"
                    android:textColor="#374151"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_google"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="10dp"
                    android:paddingStart="24dp"
                    android:layout_marginBottom="20dp"
                    android:stateListAnimator="@null" />

                <!-- ── Register Link ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="#9CA3AF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        android:textColor="#003082"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>