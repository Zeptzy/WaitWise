<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Queue Number - Big and Bold -->
        <TextView
            android:id="@+id/tvQueueNumber"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="A001"
            android:textColor="#003082"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Student Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textColor="#1F2937"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvServiceType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Document Request"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Wait Time & Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvWaitTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~5 min"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Waiting"
                android:textColor="#1D4ED8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_status_waiting" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>